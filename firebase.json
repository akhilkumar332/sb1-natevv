{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api",
        "function": "api"
      },
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "/functions/contact-submit",
        "function": "contactSubmit"
      },
      {
        "source": "/functions/error-log",
        "function": "errorLog"
      },
      {
        "source": "/functions/fcm-bridge",
        "function": "fcmBridge"
      },
      {
        "source": "/functions/frontend-access",
        "function": "frontendAccess"
      },
      {
        "source": "/functions/impersonate",
        "function": "impersonate"
      },
      {
        "source": "/functions/impersonation-resume",
        "function": "impersonationResume"
      },
      {
        "source": "/functions/admin-user-biometrics",
        "function": "adminUserBiometrics"
      },
      {
        "source": "/functions/webauthn-register-challenge",
        "function": "webauthnRegisterChallenge"
      },
      {
        "source": "/functions/webauthn-register-verify",
        "function": "webauthnRegisterVerify"
      },
      {
        "source": "/functions/webauthn-auth-challenge",
        "function": "webauthnAuthChallenge"
      },
      {
        "source": "/functions/webauthn-auth-verify",
        "function": "webauthnAuthVerify"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|js|css|woff|woff2|ttf|eot)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=31536000"
          }
        ]
      },
      {
        "source": "**/*.@(html|json)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=0, must-revalidate"
          }
        ]
      },
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "X-XSS-Protection",
            "value": "1; mode=block"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "Permissions-Policy",
            "value": "geolocation=(self), microphone=(), camera=()"
          }
        ]
      }
    ],
    "cleanUrls": true,
    "trailingSlash": false
  },
  "functions": {
    "source": "src/functions"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "firestore": {
      "port": 8080
    },
    "hosting": {
      "port": 5000
    },
    "storage": {
      "port": 9199
    },
    "ui": {
      "enabled": true,
      "port": 4000
    }
  }
}
