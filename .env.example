# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Firebase Cloud Functions secrets/config
# Store sensitive values in Firebase Secret Manager, not in frontend env files.
# Non-sensitive function runtime config should go in src/functions/.env.

# Firebase function request signing (recommended for server-to-server bridge calls)
FCM_BRIDGE_SIGNING_SECRET=replace_with_long_random_secret

# Contact form throttling
CONTACT_RATE_LIMIT_MAX_PER_MINUTE=5

# Frontend access control
FRONTEND_GATE_PASSWORD=replace_with_strong_frontend_gate_password
FRONTEND_GATE_SESSION_SECRET=replace_with_long_random_session_secret
FRONTEND_GATE_MAX_ATTEMPTS_PER_MINUTE=10

# API Configuration
VITE_API_BASE_URL=http://localhost:5001/api/v1
VITE_LOCAL_API_URL=http://localhost:5180/api/v1
VITE_PROD_API_URL=https://your-production-url.com/api/v1

# Server Port
PORT=5001

# Analytics & Monitoring (Optional)
VITE_SENTRY_DSN=
VITE_GA_TRACKING_ID=

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_TRACKING=false
VITE_ENABLE_PERFORMANCE_MONITORING=false
