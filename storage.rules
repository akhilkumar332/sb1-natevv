rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return isAuthenticated()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        ? firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function hasRole(role) {
      let userData = getUserData();
      return isAuthenticated() && userData != null && userData.role == role;
    }

    function isAdmin() {
      return hasRole('admin') || hasRole('superadmin');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidImageSize() {
      return request.resource.size < 5 * 1024 * 1024; // 5MB limit
    }

    function isValidDocumentSize() {
      return request.resource.size < 10 * 1024 * 1024; // 10MB limit
    }

    function isValidImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isValidDocument() {
      return request.resource.contentType.matches('application/pdf') ||
             request.resource.contentType.matches('image/.*');
    }

    function isHospitalOwnerOrStaff(hospitalId) {
      let userData = getUserData();
      return isAuthenticated() && (
        request.auth.uid == hospitalId ||
        isAdmin() ||
        (
          userData != null &&
          userData.parentHospitalId == hospitalId &&
          userData.staffRole in ['editor', 'manager']
        )
      );
    }

    function isBloodbankOwnerOrStaff(bloodbankId) {
      let userData = getUserData();
      return isAuthenticated() && (
        request.auth.uid == bloodbankId ||
        isAdmin() ||
        (
          userData != null &&
          userData.parentHospitalId == bloodbankId &&
          userData.staffRole in ['editor', 'manager']
        )
      );
    }

    function isNgoOwner(ngoId) {
      return isAuthenticated() && (
        request.auth.uid == ngoId ||
        isAdmin()
      );
    }

    function isCampaignOwner(campaignId) {
      return isAuthenticated() && (
        isAdmin() ||
        (
          firestore.exists(/databases/(default)/documents/campaigns/$(campaignId)) &&
          firestore.get(/databases/(default)/documents/campaigns/$(campaignId)).data.ngoId == request.auth.uid
        )
      );
    }

    // Profile pictures
    match /profiles/{userId}/{fileName} {
      allow read: if true; // Public read for profile pictures
      allow write: if isAuthenticated() &&
                     isOwner(userId) &&
                     isValidImage() &&
                     isValidImageSize();
      allow delete: if isAuthenticated() && isOwner(userId);
    }

    // BloodBank logos and images (legacy hospital path supported)
    match /hospitals/{hospitalId}/{fileName} {
      allow read: if true; // Public read
      allow write: if isHospitalOwnerOrStaff(hospitalId) &&
                     isValidImage() &&
                     isValidImageSize();
      allow delete: if isHospitalOwnerOrStaff(hospitalId);
    }

    match /bloodbanks/{bloodbankId}/{fileName} {
      allow read: if true; // Public read
      allow write: if isBloodbankOwnerOrStaff(bloodbankId) &&
                     isValidImage() &&
                     isValidImageSize();
      allow delete: if isBloodbankOwnerOrStaff(bloodbankId);
    }

    // Campaign images
    match /campaigns/{campaignId}/{fileName} {
      allow read: if true; // Public read
      allow write: if isCampaignOwner(campaignId) &&
                     isValidImage() &&
                     isValidImageSize();
      allow delete: if isCampaignOwner(campaignId);
    }

    // Verification documents (bloodbanks, NGOs)
    match /verification/{userId}/{fileName} {
      allow read: if isAuthenticated() &&
                    (isOwner(userId) ||
                     isAdmin());
      allow write: if isAuthenticated() &&
                     isOwner(userId) &&
                     isValidDocument() &&
                     isValidDocumentSize();
      allow delete: if false;
    }

    // Donation certificates
    match /certificates/{donorId}/{fileName} {
      allow read: if isAuthenticated() &&
                    (isOwner(donorId) ||
                     isAdmin());
      allow write: if isAuthenticated() &&
                     isAdmin() &&
                     isValidDocument() &&
                     isValidDocumentSize();
      allow delete: if false; // Certificates should not be deleted
    }

    // NGO documents
    match /ngos/{ngoId}/{fileName} {
      allow read: if true; // Public read
      allow write: if isNgoOwner(ngoId) &&
                     isValidImage() &&
                     isValidImageSize();
      allow delete: if isNgoOwner(ngoId);
    }

    // Default deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
